@using PetCareManagement.Data
@inject PetCareDbContext _layoutCtx

@{
   var homNayLayout  = DateOnly.FromDateTime(DateTime.Today);
    var sau7NgayLayout = homNayLayout.AddDays(7);

    var soCanhBao = _layoutCtx.TiemPhongs.Count(t =>
        (t.NgayTiem >= homNayLayout && t.NgayTiem <= sau7NgayLayout) ||
        (t.NgayTiemTiep.HasValue &&
         t.NgayTiemTiep.Value >= homNayLayout &&
         t.NgayTiemTiep.Value <= sau7NgayLayout));
}
<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PetCare</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/PetCareManagement.styles.css" asp-append-version="true" />
</head>

<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom shadow-sm mb-3">
            <div class="container-fluid">

                <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                    🐾 PetCare
                </a>

                <button class="navbar-toggler" type="button"
                        data-bs-toggle="collapse" data-bs-target="#navMain"
                        aria-controls="navMain" aria-expanded="false">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navMain">
                    @* Menu trái *@
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">🏠 Trang chủ</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="ThuCung" asp-action="Index">🐾 Thú cưng</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="LichHen" asp-action="Index">📅 Lịch hẹn</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="TiemPhong" asp-action="Index">
                                💉 Tiêm phòng
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="TiemPhong"
                               asp-action="CanhBao">
                                🔔 Cảnh báo

                                @if (soCanhBao > 0)
                                {
                                    <span class="badge bg-danger rounded-pill">
                                        @soCanhBao
                                    </span>
                          }
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="DichVu" asp-action="Index">✂️ Dịch vụ</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="HoaDon" asp-action="Index">🧾 Hoá đơn</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="BaoCao" asp-action="DoanhThu">📊 Báo cáo</a>
                        </li>
                    </ul>

                    @* Thông tin người dùng + Đăng xuất *@
                    @{
                        var tenNV = Context.Session.GetString("NhanVienName");
                        var vaiTro = Context.Session.GetString("NhanVienRole");
                    }
                    @if (tenNV != null)
                    {
                        <ul class="navbar-nav">
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle d-flex align-items-center gap-1"
                                   href="#" role="button" data-bs-toggle="dropdown">
                                    <span class="badge bg-success rounded-circle p-1" style="font-size:9px">●</span>
                                    <span class="fw-semibold">@tenNV</span>
                                    <small class="text-muted">(@vaiTro)</small>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li>
                                        <form asp-controller="Auth" asp-action="Logout" method="post">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="dropdown-item text-danger">
                                                🚪 Đăng xuất
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        </ul>
                    }
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        @* TempData thông báo toàn cục *@
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                ✅ @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                ❌ @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-4">
        <div class="container py-2">
            &copy; 2026 — PetCare Management System
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" integrity="sha512-9usAa10IRO0HhonpyAIVpjrylPvoDwiPUiKdWk5t3PyolY1cOd4DSE0Ga+ri4AuTroPR5aQvXU9xC6qOPnzFeg==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

@{
    
    // Lấy thông tin tên khách hàng từ Session (nếu bạn có lưu)
    var tenKhachHang = Context.Session.GetString("ChuNuoiName") ?? Context.Session.GetString("NhanVienName");
}
<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Cổng Thông Tin Chủ Nuôi</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/PetCareManagement.styles.css" asp-append-version="true" />
</head>

<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom shadow-sm mb-3">
            <div class="container-fluid">

                <a class="navbar-brand fw-bold" href="/ChuNuoi/Index">
                    🐾 PetCare <small class="text-muted" style="font-size: 11px; font-weight: normal;">(Khách hàng)</small>
                </a>

                <button class="navbar-toggler" type="button"
                        data-bs-toggle="collapse" data-bs-target="#navMain"
                        aria-controls="navMain" aria-expanded="false">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navMain">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link fw-bold text-primary" href="/ChuNuoi/LichSuDatLich">
                                📋Lịch Sử Đặt Lịch
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link fw-bold text-success" href="/ChuNuoi/DatLich">
                                ➕ Đặt Lịch Hẹn Mới
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/ChuNuoi/DanhSachTiemPhong">
                                🐾 Lịch Tiêm Phòng Của Thú Cưng
                            </a>
                        </li>
                         <li class="nav-item">
                            <a class="nav-link" href="/ChuNuoi/DanhSachThuCung">
                                🐾 Danh Sách Thú Cưng Của Bạn
                            </a>
                        </li>
                    </ul>

                    @* Hiển thị tên người dùng và nút Đăng xuất *@
                    @if (tenKhachHang != null)
                    {
                        <ul class="navbar-nav">
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle d-flex align-items-center gap-1"
                                   href="#" role="button" data-bs-toggle="dropdown">
                                    <span class="badge bg-success rounded-circle p-1" style="font-size:9px">●</span>
                                    <span class="fw-semibold">@tenKhachHang</span>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end">
                                        <li>
                                            <a class="dropdown-item py-2" href="/ChuNuoi/ThongTinChuNuoi">
                                                👤 Thông Tin Chủ Nuôi
                                            </a>
                                        </li>
                                        <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form asp-controller="Auth" asp-action="Logout" method="post">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="dropdown-item text-danger">
                                                🚪 Đăng xuất
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        </ul>
                    }
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        @* Bộ thông báo TempData giữ nguyên từ bản gốc của bạn *@
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                ✅ @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                ❌ @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    @* Footer giữ nguyên giao diện đơn giản như mẫu bạn gửi *@
    <footer class="border-top footer text-muted mt-4">
        <div class="container py-2">
            &copy; 2026 — PetCare Management System
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" integrity="sha512-9usAa10IRO0HhonpyAIVpjrylPvoDwiPUiKdWk5t3PyolY1cOd4DSE0Ga+ri4AuTroPR5aQvXU9xC6qOPnzFeg==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
@{
    ViewData["Title"] = "Báo cáo doanh thu";
}

<div class="mb-3">
    <h3 class="mb-1">📊 Báo cáo doanh thu</h3>
    <p class="text-muted mb-0">Biểu đồ doanh thu 6 tháng gần nhất.</p>
</div>

<div class="card shadow-sm p-3">
    <p class="mb-2">Tháng này: <strong>@ViewBag.TongThangNay.ToString("N0") VNĐ</strong></p>
    <div style="max-width: 800px;">
        <canvas id="chartDoanhThu"></canvas>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        new Chart(document.getElementById('chartDoanhThu'), {
            type: 'bar',
            data: {
                labels: @Html.Raw(ViewBag.Labels),
                datasets: [{
                    label: 'Doanh thu (VNĐ)',
                    data: @Html.Raw(ViewBag.DoanhThu),
                    backgroundColor: 'rgba(34, 197, 94, 0.55)',
                    borderColor: 'rgba(22, 163, 74, 1)',
                    borderWidth: 1
                }]
            },
            options: {
                responsive: true,
                scales: { y: { beginAtZero: true } }
            }
        });
    </script>
}

@model ThuCung

@{
    ViewData["Title"] = "Xoá thú cưng";
    var icon = Model.Loai == "Chó" ? "🐶" : Model.Loai == "Mèo" ? "🐱" : "🐾";
}

<div class="d-flex align-items-center mb-3 gap-2">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">← Quay lại</a>
    <h5 class="mb-0 text-danger">🗑️ Xoá thú cưng</h5>
</div>

<div class="card border-danger shadow-sm" style="max-width:540px">
    <div class="card-header bg-danger text-white">
        <h6 class="mb-0">⚠️ Xác nhận xoá</h6>
    </div>
    <div class="card-body">
        <p class="mb-3">Bạn có chắc muốn xoá hồ sơ thú cưng dưới đây không?
           Hành động này <strong>không thể hoàn tác</strong>.</p>

        <dl class="row">
            <dt class="col-5 text-muted">Tên thú cưng</dt>
            <dd class="col-7 fw-semibold">@icon @Model.TenThuCung</dd>

            <dt class="col-5 text-muted">Loài / Giống</dt>
            <dd class="col-7">@Model.Loai @(!string.IsNullOrEmpty(Model.Giong) ? $"— {Model.Giong}" : "")</dd>

            <dt class="col-5 text-muted">Chủ nuôi</dt>
            <dd class="col-7">@Model.MaCnNavigation?.HoTen</dd>

            <dt class="col-5 text-muted">Ngày sinh</dt>
            <dd class="col-7">
                @(Model.NgaySinh.HasValue ? Model.NgaySinh.Value.ToString("dd/MM/yyyy") : "—")
            </dd>
        </dl>

        @{
            var lichHenCount   = Model.LichHens?.Count ?? 0;
            var tiemPhongCount = Model.TiemPhongs?.Count ?? 0;
            var hoaDonCount    = Model.LichHens?.Sum(l => l.HoaDons?.Count ?? 0) ?? 0;
        }

        @if (lichHenCount > 0 || tiemPhongCount > 0)
        {
            <div class="alert alert-warning mb-3 small">
                ⚠️ Thú cưng này còn <strong>@lichHenCount lịch hẹn</strong>,
                <strong>@tiemPhongCount bản ghi tiêm phòng</strong>
                @if (hoaDonCount > 0)
                {
                    <span>và <strong>@hoaDonCount hoá đơn</strong></span>
                }.
                Tất cả dữ liệu liên quan cũng sẽ bị xoá.
            </div>
        }

        <form asp-action="Delete" asp-route-id="@Model.MaTc" method="post">
            @Html.AntiForgeryToken()
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-danger">
                    🗑️ Xác nhận xoá
                </button>
                <a asp-action="Details" asp-route-id="@Model.MaTc"
                   class="btn btn-outline-secondary">Huỷ</a>
            </div>
        </form>
    </div>
</div>

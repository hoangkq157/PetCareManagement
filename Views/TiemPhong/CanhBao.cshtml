@model List<PetCareManagement.Models.TiemPhong>
@{ ViewData["Title"] = "Cảnh báo tiêm phòng"; }

<div class="card shadow-sm border-0">
    <div class="card-header bg-warning text-dark d-flex justify-content-between align-items-center">
        <h4 class="mb-0">⚠️ Cảnh báo tiêm phòng trong 7 ngày tới</h4>
        <a asp-action="Index" class="btn btn-outline-dark btn-sm">↩ Quay lại</a>
    </div>
    <div class="card-body">

        @if (!Model.Any())
        {
            <div class="alert alert-success mb-0">
                ✅ Không có lịch tiêm phòng nào trong 7 ngày tới.
            </div>
        }
        else
        {
            <p class="text-muted mb-3">
                Có <strong>@Model.Count</strong> lịch tiêm cần chú ý trong 7 ngày tới.
            </p>

            <table class="table table-bordered align-middle">
                <thead class="table-light">
                    <tr class="text-center">
                        <th>Tên thú cưng</th>
                        <th>Chủ nuôi</th>
                        <th>SĐT</th>
                        <th>Vaccine</th>
                        <th>Loại cảnh báo</th>
                        <th>Ngày</th>
                        <th>Còn lại</th>
                    </tr>
                </thead>
                <tbody>
                @{
                    var homNay   = DateOnly.FromDateTime(DateTime.Today);
                    var sau7Ngay = homNay.AddDays(7);
                }
                @foreach (var tp in Model)
                {
                    // Kiểm tra loại nào trong 7 ngày
                    bool tiem    = tp.NgayTiem >= homNay && tp.NgayTiem <= sau7Ngay;
                    bool tiemTiep = tp.NgayTiemTiep.HasValue &&
                                    tp.NgayTiemTiep.Value >= homNay &&
                                    tp.NgayTiemTiep.Value <= sau7Ngay;

                    // Dùng ngày gần nhất để tính còn lại
                    DateOnly ngayCanh = tiem ? tp.NgayTiem : tp.NgayTiemTiep!.Value;
                    int conLai = ngayCanh.DayNumber - homNay.DayNumber;
                    string rowClass = conLai <= 3 ? "table-danger" : "table-warning";

                    <tr class="@rowClass">
                        <td>@tp.MaTcNavigation?.TenThuCung</td>
                        <td>@tp.MaTcNavigation?.MaCnNavigation?.HoTen</td>
                        <td>@tp.MaTcNavigation?.MaCnNavigation?.SoDienThoai</td>
                        <td>@tp.TenVaccine</td>
                        <td class="text-center">
                            @if (tiem)
                            {
                                <span class="badge bg-primary">Ngày tiêm</span>
                            }
                            @if (tiemTiep)
                            {
                                <span class="badge bg-info text-dark">Tiêm tiếp theo</span>
                            }
                        </td>
                        <td class="text-center">@ngayCanh.ToString("dd/MM/yyyy")</td>
                        <td class="text-center fw-bold">
                            @(conLai == 0 ? "Hôm nay!" : $"Còn {conLai} ngày")
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        }

    </div>
</div>
@model IEnumerable<PetCareManagement.Models.HoaDon>
@{
    ViewData["Title"] = "Danh sách hoá đơn";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h3 class="mb-1">🧾 Hoá đơn</h3>
        <p class="text-muted mb-0">Theo dõi hoá đơn và trạng thái thanh toán.</p>
    </div>
    <a class="btn btn-outline-primary" asp-controller="BaoCao" asp-action="DoanhThu">📊 Báo cáo doanh thu</a>
</div>

<table class="table table-bordered table-hover align-middle">
    <thead class="table-light">
        <tr>
            <th>Mã HĐ</th>
            <th>Lịch hẹn</th>
            <th>Chủ nuôi</th>
            <th>Ngày lập</th>
            <th>Tổng tiền</th>
            <th>Trạng thái</th>
            <th>Thanh toán</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            var daThanhToan = item.TrangThaiTt == "DaThanhToan" || (item.SoTienKhachTra ?? 0) >= item.TongTien;
            <tr>
                <td>#@item.MaHd</td>
                <td>@item.MaLh</td>
                <td>@item.MaCnNavigation?.HoTen</td>
                <td>@item.NgayLap.ToString("dd/MM/yyyy")</td>
                <td>@item.TongTien.ToString("N0") VNĐ</td>
                <td>
                    @if (daThanhToan)
                    {
                        <span class="badge bg-success">Đã thanh toán</span>
                    }
                    else if (item.TrangThaiTt == "ThanhToanMotPhan")
                    {
                        <span class="badge bg-info text-dark">Thanh toán một phần</span>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark">Chưa thanh toán</span>
                    }
                </td>
                <td>
                    @if (daThanhToan)
                    {
                        <div class="small text-muted">Phương thức: @(item.PhuongThucTt ?? "—")</div>
                        <div class="small text-muted">Khách trả: @((item.SoTienKhachTra ?? 0).ToString("N0")) VNĐ</div>
                        @if ((item.TienThua ?? 0) > 0)
                        {
                            <div class="small text-success">Tiền thừa: @((item.TienThua ?? 0).ToString("N0")) VNĐ</div>
                        }
                    }
                    else
                    {
                        <button type="button" class="btn btn-sm btn-success" data-bs-toggle="modal" data-bs-target="#modalThanhToan-@item.MaHd">Thanh toán</button>
                        <div class="small text-muted mt-1">Còn lại: @((item.TongTien - (item.SoTienKhachTra ?? 0)).ToString("N0")) VNĐ</div>

                        <div class="modal fade" id="modalThanhToan-@item.MaHd" tabindex="-1" aria-hidden="true">
                            <div class="modal-dialog modal-lg">
                                <div class="modal-content">
                                    <form asp-action="ThanhToan" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.MaHd" />
                                        <div class="modal-header">
                                            <h5 class="modal-title">Thanh toán hóa đơn #@item.MaHd</h5>
                                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                        </div>
                                        <div class="modal-body">
                                            <div class="row g-3">
                                                <div class="col-md-6">
                                                    <label class="form-label">Chủ nuôi</label>
                                                    <input class="form-control" value="@item.MaCnNavigation?.HoTen" disabled />
                                                </div>
                                                <div class="col-md-6">
                                                    <label class="form-label">Tổng tiền</label>
                                                    <input class="form-control" value="@item.TongTien.ToString("N0") VNĐ" disabled />
                                                </div>
                                                <div class="col-md-6">
                                                    <label class="form-label">Số tiền khách trả</label>
                                                    <input type="number" min="0" step="1000" name="soTienKhachTra" class="form-control" required />
                                                </div>
                                                <div class="col-md-6">
                                                    <label class="form-label">Phương thức thanh toán</label>
                                                    <select name="phuongThuc" class="form-select">
                                                        <option value="TienMat">Tiền mặt</option>
                                                        <option value="ChuyenKhoan">Chuyển khoản</option>
                                                    </select>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="modal-footer">
                                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                                            <button type="submit" class="btn btn-success">Xác nhận thanh toán</button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

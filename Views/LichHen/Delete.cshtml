@model PetCareManagement.Models.LichHen

@{
    ViewData["Title"] = "Delete";
}

<h1>Xóa Lịch Hẹn</h1>

<h3>Are you sure you want to delete this?</h3>
<div>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
           Ngày Hẹn
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.NgayHen)
        </dd>
        <dt class = "col-sm-2">
            Giờ Hẹn
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.GioHen)
        </dd>
        <dt class = "col-sm-2">
            Trạng Thái
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.TrangThai)
        </dd>
        <dt class = "col-sm-2">
            Ghi Chú
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.GhiChu)
        </dd>
        <dt class = "col-sm-2">
            Ngày Tạo
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.NgayTao)
        </dd>
        <dt class = "col-sm-2">
            Nhân Viên Chăm Sóc
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.MaNvNavigation.HoTen)
        </dd>
        <dt class = "col-sm-2">
            Tên Thú Cưng
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.MaTcNavigation.TenThuCung)
        </dd>
    </dl>
    
    <form asp-action="Delete">
        <input type="hidden" asp-for="MaLh" />
        <input type="submit" value="Delete" class="btn btn-danger" /> |
        <a asp-action="Index">Quay lại danh sách Lịch Hẹn</a>
    </form>
</div>

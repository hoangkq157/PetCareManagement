@model IEnumerable<PetCareManagement.Models.LichHen>

@{
    ViewData["Title"] = "Danh sách lịch hẹn";
}

<h1>Danh Sách Lịch Hẹn</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Tạo Lịch Hẹn Mới</a>
</p>

<form asp-action="Index" method="get" class="mb-3">
    <div class="row g-2 align-items-center">
        <div class="col-auto">
            <input type="text" name="searchTenChuNuoi" value="@ViewBag.SearchTenChuNuoi" class="form-control" placeholder="Nhập tên chủ nuôi..." />
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-info text-white">Tìm kiếm</button>
            <a asp-action="Index" class="btn btn-secondary">Xóa bộ lọc</a>
        </div>
    </div>
</form>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>#</th>
            <th>
                Ngày Hẹn
            </th>
            <th>
                Giờ Hẹn
            </th>
            <th>
                Tên Chủ Nuôi </th>
            <th>
                Tên Thú Cưng
            </th>
            <th>
                Tên Dịch Vụ </th>
            <th>
                Trạng Thái
            </th>
            <th>
                Ghi Chú
            </th>
            <th>
                Ngày Tạo
            </th>
            <th>
                Tên Nhân Viên
            </th>
            <th>Hành động</th>
        </tr>
    </thead>
    <tbody>
@{
    int stt = 1;
}
@foreach (var item in Model) {
        <tr>
            <td class="text-center text-muted">@stt</td>
            <td>
                @Html.DisplayFor(modelItem => item.NgayHen)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.GioHen)
            </td>
            <td>
                @item.MaTcNavigation?.MaCnNavigation?.HoTen
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.MaTcNavigation.TenThuCung)
            </td>
            <td>
                @if (item.LichHenDichVus != null && item.LichHenDichVus.Any())
                {
                    @string.Join(", ", item.LichHenDichVus.Select(ld => ld.MaDvNavigation?.TenDichVu))
                }
                else
                {
                    <span class="text-muted">Chưa chọn dịch vụ</span>
                }
            </td>
            <td>
                @if (item.TrangThai == "HoanThanh")
                {
                    <span class="badge bg-success">✓ Hoàn thành</span>
                }
                else if (item.TrangThai == "XacNhan")
                {
                    <span class="badge bg-primary">✓ Đã xác nhận</span>
                }
                else if (item.TrangThai == "Huy")
                {
                    <span class="badge bg-danger">✕ Đã huỷ</span>
                }
                else
                {
                    <span class="badge bg-warning text-dark">⏳ Chờ duyệt</span>
                }
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.GhiChu)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.NgayTao)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.MaNvNavigation.HoTen)
            </td>
            <td style="white-space: nowrap;">

    @if (item.TrangThai == "ChoDuyet")
    {
        <form asp-action="DoiTrangThai"
              method="post"
              style="display:inline">
            <input type="hidden" name="id" value="@item.MaLh" />
            <input type="hidden" name="trangThai" value="XacNhan" />
            <button type="submit"
                    class="btn btn-success btn-sm">
                Xác nhận
            </button>
        </form>

        <form asp-action="DoiTrangThai"
              method="post"
              style="display:inline">
            <input type="hidden" name="id" value="@item.MaLh" />
            <input type="hidden" name="trangThai" value="Huy" />
            <button type="submit"
                    class="btn btn-danger btn-sm">
                Huỷ
            </button>
        </form>
    }
    else
    {
        <a asp-action="Edit"
           asp-route-id="@item.MaLh"
           class="btn btn-warning btn-sm">
            Sửa
        </a>

        <a asp-action="Details"
           asp-route-id="@item.MaLh"
           class="btn btn-info btn-sm">
            Chi tiết
        </a>

        <a asp-action="Delete"
           asp-route-id="@item.MaLh"
           class="btn btn-secondary btn-sm">
            Xóa
        </a>

        <form asp-controller="HoaDon" asp-action="TaoHoaDon" method="post" style="display:inline">
            @Html.AntiForgeryToken()
            <input type="hidden" name="maLh" value="@item.MaLh" />
            <button type="submit" class="btn btn-success btn-sm">Tạo HĐ</button>
        </form>
    }

</td>
        </tr>
    stt++;
}
    </tbody>
</table>
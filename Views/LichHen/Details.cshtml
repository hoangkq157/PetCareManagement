@model PetCareManagement.Models.LichHen

@{
    ViewData["Title"] = "Details";
}

<h1>Chi Tiết Lịch Hẹn</h1>

<div>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
           Ngày Hẹn
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.NgayHen)
        </dd>
        <dt class = "col-sm-2">
            Giờ Hẹn
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.GioHen)
        </dd>
        <dt class = "col-sm-2">
            Trạng Thái
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.TrangThai)
        </dd>
        <dt class = "col-sm-2">
            Ghi Chú
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.GhiChu)
        </dd>
        <dt class = "col-sm-2">
            Ngày Tạo
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.NgayTao)
        </dd>
        <dt class = "col-sm-2">
            Nhân Viên Chăm Sóc
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.MaNvNavigation.HoTen)
        </dd>
        <dt class = "col-sm-2">
            Tên Thú Cưng
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.MaTcNavigation.TenThuCung)
        </dd>
    </dl>
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model?.MaLh">Chỉnh sửa lịch hẹn</a> |
    <a asp-action="Index">Quay lại danh sách Lịch Hẹn</a>
</div>

@model PetCareManagement.Models.LichHen

@{
    ViewData["Title"] = "Details";
}

<h1>Chi Tiết Lịch Hẹn</h1>

<div>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
           Ngày Hẹn
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.NgayHen)
        </dd>
        <dt class = "col-sm-2">
            Giờ Hẹn
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.GioHen)
        </dd>
        <dt class = "col-sm-2">
            Trạng Thái
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.TrangThai)
        </dd>
        <dt class = "col-sm-2">
            Ghi Chú
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.GhiChu)
        </dd>
        <dt class = "col-sm-2">
            Ngày Tạo
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.NgayTao)
        </dd>
        <dt class = "col-sm-2">
            Nhân Viên Chăm Sóc
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.MaNvNavigation.HoTen)
        </dd>
        <dt class = "col-sm-2">
            Tên Thú Cưng
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.MaTcNavigation.TenThuCung)
        </dd>
    </dl>
</div>
<div class="mt-4">
    <h5>📋 Dịch vụ trong lịch hẹn</h5>
    @if (Model.LichHenDichVus != null && Model.LichHenDichVus.Any())
    {
        <table class="table table-bordered table-sm">
            <thead class="table-light">
                <tr>
                    <th>Dịch vụ</th>
                    <th>Số lượng</th>
                    <th>Đơn giá</th>
                    <th>Thành tiền</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.LichHenDichVus)
                {
                    var thanhTien = item.SoLuong * item.DonGia;
                    <tr>
                        <td>@item.MaDvNavigation?.TenDichVu</td>
                        <td>@item.SoLuong</td>
                        <td>@item.DonGia.ToString("N0") VNĐ</td>
                        <td>@thanhTien.ToString("N0") VNĐ</td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr>
                    <th colspan="3" class="text-end">Tổng tiền tự tính</th>
                    <th>@Model.LichHenDichVus.Sum(x => x.SoLuong * x.DonGia).ToString("N0") VNĐ</th>
                </tr>
            </tfoot>
        </table>

        <form asp-controller="HoaDon" asp-action="TaoHoaDon" method="post" class="d-inline">
            @Html.AntiForgeryToken()
            <input type="hidden" name="maLh" value="@Model.MaLh" />
            <button type="submit" class="btn btn-success">🧾 Tạo hóa đơn từ lịch hẹn</button>
        </form>
    }
    else
    {
        <p class="text-muted">Chưa có dịch vụ nào được gắn vào lịch hẹn này.</p>
    }
</div>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model?.MaLh" class="btn btn-warning btn-sm">Chỉnh sửa lịch hẹn</a>
    <a asp-action="Index" class="btn btn-secondary btn-sm">Quay lại danh sách Lịch Hẹn</a>
</div>

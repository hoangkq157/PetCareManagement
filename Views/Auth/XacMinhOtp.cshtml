@{
    ViewData["Title"] = "Xác minh OTP";
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Xác minh OTP — PetCare</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        body {
            background: linear-gradient(135deg, #e8f5e9 0%, #e3f2fd 100%);
            min-height: 100vh;
            display: flex; align-items: center; justify-content: center;
        }
        .card {
            width: 100%; max-width: 420px;
            border: none; border-radius: 16px;
            box-shadow: 0 8px 32px rgba(0,0,0,0.12);
        }
        .card-header {
            background: linear-gradient(135deg, #43a047, #1e88e5);
            border-radius: 16px 16px 0 0;
            padding: 36px 32px 28px;
            text-align: center; color: white;
        }
        .card-header .logo { font-size: 48px; }
        .card-header h1 { font-size: 20px; font-weight: 700; margin: 8px 0 4px; }
        .card-header p  { font-size: 13px; opacity: .85; margin: 0; }
        .card-body { padding: 32px; }
        .btn-submit {
            background: linear-gradient(135deg, #43a047, #1e88e5);
            border: none; border-radius: 8px;
            padding: 10px; font-weight: 600;
        }
        .btn-submit:hover { opacity: .9; }
        .step-indicator {
            font-size: 12px; color: #999;
            text-align: center; margin-bottom: 20px;
        }
        .step-indicator span {
            display: inline-block; width: 28px; height: 28px;
            line-height: 28px; border-radius: 50%;
            background: #e0e0e0; color: #999;
            font-weight: 700; margin: 0 4px;
        }
        .step-indicator span.active { background: #1e88e5; color: white; }
        .step-indicator span.done   { background: #43a047; color: white; }
        .otp-input {
            font-size: 28px; font-weight: 700;
            letter-spacing: 10px; text-align: center;
            border-radius: 10px; border: 2px solid #1e88e5;
        }
        .otp-input:focus {
            box-shadow: 0 0 0 3px rgba(30,136,229,.25); outline: none;
        }
        #countdown { font-size: 13px; color: #e53935; font-weight: 600; }
    </style>
</head>
<body>
<div class="card">
    <div class="card-header">
        <div class="logo">📧</div>
        <h1>Nhập mã OTP</h1>
        <p>Kiểm tra hộp thư email của bạn</p>
    </div>
    <div class="card-body">

        <div class="step-indicator">
            <span class="done">✓</span> Nhập email
            <span class="active">2</span> Xác minh OTP
            <span>3</span> Mật khẩu mới
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger py-2 mb-3">⚠️ @ViewBag.Error</div>
        }

        <p class="text-muted text-center mb-3" style="font-size:13px">
            Mã OTP gồm 6 chữ số đã được gửi về email của bạn.<br />
            <span id="countdown">Mã hết hạn sau 5:00</span>
        </p>

        <form asp-action="XacMinhOtp" method="post">
            @Html.AntiForgeryToken()
            <div class="mb-4">
                <input type="text" name="otp" class="form-control otp-input"
                       maxlength="6" placeholder="· · · · · ·"
                       autocomplete="one-time-code" inputmode="numeric"
                       required autofocus />
            </div>
            <button type="submit" class="btn btn-primary btn-submit w-100">
                Xác minh OTP
            </button>
        </form>

        <div class="text-center mt-3">
            <a asp-action="QuenMatKhau" style="font-size:13px;color:#1e88e5">
                ↺ Gửi lại mã / dùng email khác
            </a>
        </div>
        <p class="text-center text-muted mt-3 mb-0" style="font-size:12px">
            &copy; 2026 PetCare Management System
        </p>
    </div>
</div>

<script>
    // Đếm ngược 5 phút
    let seconds = 300;
    const el = document.getElementById('countdown');
    const timer = setInterval(() => {
        seconds--;
        if (seconds <= 0) {
            clearInterval(timer);
            el.textContent = 'Mã OTP đã hết hạn. Vui lòng yêu cầu mã mới.';
            return;
        }
        const m = Math.floor(seconds / 60).toString();
        const s = (seconds % 60).toString().padStart(2, '0');
        el.textContent = `Mã hết hạn sau ${m}:${s}`;
    }, 1000);

    // Chỉ cho nhập số
    document.querySelector('input[name=otp]').addEventListener('input', function () {
        this.value = this.value.replace(/\D/g, '').slice(0, 6);
    });
</script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
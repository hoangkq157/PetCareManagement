@model IEnumerable<PetCareManagement.Models.ThuCung>

@{
    ViewData["Title"] = "Thú Cưng Của Tôi";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-primary mb-1">🐾 Thú Cưng Của Tôi</h2>
            <p class="text-muted mb-0">Quản lý danh sách các bé thú cưng mà bạn đang gửi gắm tại hệ thống.</p>
        </div>
        <a href="/ChuNuoi/DatLich" class="btn btn-success fw-bold shadow-sm px-4 py-2">
            <i class="fas fa-calendar-plus me-2"></i> Đặt Dịch Vụ Ngay
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5 border rounded bg-light shadow-sm">
            <div class="mb-3 text-muted" style="font-size: 3rem;">🐕🐈</div>
            <h4 class="text-secondary">Bạn chưa có thú cưng nào!</h4>
            <p class="text-muted">Vui lòng liên hệ nhân viên tại quầy để đăng ký thêm thông tin thú cưng mới.</p>
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0 rounded-3 overflow-hidden">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-dark text-uppercase fs-7">
                        <tr class="text-center">
                            <th class="ps-4 text-start">Tên Thú Cưng</th>
                            <th>Loài & Giống</th>
                            <th>Ngày Sinh</th>
                            <th>Cân Nặng</th>
                            <th>Màu Lông</th>
                            <th class="pe-4 text-center">Thao Tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var tc in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center">
                                        <span class="fs-4 me-3">@(tc.Loai == "Chó" ? "🐶" : tc.Loai == "Mèo" ? "🐱" : "🐾")</span>
                                        <div>
                                            <div class="fw-bold text-dark fs-6">@tc.TenThuCung</div>
                                            <small class="text-muted">Mã số: #@tc.MaTc</small>
                                        </div>
                                    </div>
                                </td>

                                <td class="text-center">
                                    @if (tc.Loai == "Chó")
                                    {
                                        <span class="badge bg-warning text-dark border">Chó</span>
                                    }
                                    else if (tc.Loai == "Mèo")
                                    {
                                        <span class="badge bg-info text-dark border">Mèo</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary border">@(tc.Loai ?? "—")</span>
                                    }
                                    <div class="small text-muted mt-1">@(tc.Giong ?? "—")</div>
                                </td>

                                <td class="text-center fw-medium text-secondary">
                                    @(tc.NgaySinh.HasValue ? tc.NgaySinh.Value.ToString("dd/MM/yyyy") : "—")
                                </td>

                                <td class="text-center fw-medium text-secondary">
                                    @(tc.CanNang.HasValue ? tc.CanNang.Value.ToString("0.##") + " kg" : "—")
                                </td>

                                <td class="text-center text-muted">
                                    @(tc.MauLong ?? "—")
                                </td>

                                <td class="pe-4 text-center">
                                    <form asp-controller="ChuNuoi" asp-action="XoaThuCung" method="post" 
                                          onsubmit="return confirm('Bạn có chắc chắn muốn xóa @tc.TenThuCung khỏi danh sách không?');">
                                        <input type="hidden" name="id" value="@tc.MaTc" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3">
                                            🗑️ Xoá
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <div class="text-end mt-3 text-muted small">
            Tổng cộng: <strong>@Model.Count()</strong> thú cưng
        </div>
    }
</div>

<style>
    /* Kế thừa một chút class CSS dùng chung để giao diện sắc nét */
    .fs-7 { font-size: 0.85rem; }
</style>
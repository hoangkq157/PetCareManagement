@{
    ViewData["Title"] = "Đổi Mật Khẩu";
    Layout = "~/Views/Shared/_LayoutChuNuoi.cshtml";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-5">

            <div class="d-flex align-items-center gap-3 mb-4">
                <a asp-action="ThongTinCaNhan" class="btn btn-sm btn-outline-secondary">
                    <i class="fas fa-arrow-left"></i>
                </a>
                <div>
                    <h2 class="fw-bold text-primary mb-0">🔑 Đổi Mật Khẩu</h2>
                    <p class="text-muted mb-0 small">Bảo mật tài khoản của bạn</p>
                </div>
            </div>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    ❌ @ViewBag.Error
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <div class="card border-0 shadow-sm rounded-4 p-4">

                <div class="text-center mb-4">
                    <div class="mx-auto d-flex align-items-center justify-content-center rounded-circle bg-warning-subtle mb-3"
                         style="width:64px;height:64px;font-size:1.8rem;">
                        🔒
                    </div>
                    <p class="text-muted small">Mật khẩu mới phải có ít nhất <strong>6 ký tự</strong>.</p>
                </div>

                <form asp-action="DoiMatKhau" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label fw-semibold">
                            Mật Khẩu Hiện Tại <span class="text-danger">*</span>
                        </label>
                        <div class="input-group">
                            <span class="input-group-text bg-light"><i class="fas fa-lock text-secondary"></i></span>
                            <input type="password" name="matKhauCu" id="matKhauCu"
                                   class="form-control rounded-end" placeholder="Nhập mật khẩu hiện tại" required />
                            <button class="btn btn-outline-secondary" type="button"
                                    onclick="togglePwd('matKhauCu', this)" tabindex="-1">
                                <i class="fas fa-eye"></i>
                            </button>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">
                            Mật Khẩu Mới <span class="text-danger">*</span>
                        </label>
                        <div class="input-group">
                            <span class="input-group-text bg-light"><i class="fas fa-key text-primary"></i></span>
                            <input type="password" name="matKhauMoi" id="matKhauMoi"
                                   class="form-control rounded-end" placeholder="Tối thiểu 6 ký tự" required />
                            <button class="btn btn-outline-secondary" type="button"
                                    onclick="togglePwd('matKhauMoi', this)" tabindex="-1">
                                <i class="fas fa-eye"></i>
                            </button>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold">
                            Xác Nhận Mật Khẩu Mới <span class="text-danger">*</span>
                        </label>
                        <div class="input-group">
                            <span class="input-group-text bg-light"><i class="fas fa-check-circle text-success"></i></span>
                            <input type="password" name="xacNhanMatKhau" id="xacNhanMatKhau"
                                   class="form-control rounded-end" placeholder="Nhập lại mật khẩu mới" required />
                            <button class="btn btn-outline-secondary" type="button"
                                    onclick="togglePwd('xacNhanMatKhau', this)" tabindex="-1">
                                <i class="fas fa-eye"></i>
                            </button>
                        </div>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-warning fw-bold py-2 rounded-3 text-dark">
                            <i class="fas fa-shield-alt me-2"></i>Xác Nhận Đổi Mật Khẩu
                        </button>
                        <a asp-action="ThongTinChuNuoi" class="btn btn-outline-secondary rounded-3">
                            Hủy
                        </a>
                    </div>
                </form>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        function togglePwd(fieldId, btn) {
            var input = document.getElementById(fieldId);
            var icon = btn.querySelector('i');
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.replace('fa-eye', 'fa-eye-slash');
            } else {
                input.type = 'password';
                icon.classList.replace('fa-eye-slash', 'fa-eye');
            }
        }
    </script>
}
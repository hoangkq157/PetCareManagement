@model PetCareManagement.Models.ChuNuoi

@{
    ViewData["Title"] = "Chi tiết chủ nuôi";
}

<div class="d-flex align-items-center mb-3 gap-2">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">← Danh sách chủ nuôi</a>
    <h5 class="mb-0">👤 Chi tiết chủ nuôi — <span class="text-primary">@Model.HoTen</span></h5>
</div>

<div class="row g-4">
    <div class="col-lg-6">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-primary text-white">
                <h6 class="mb-0">Thông tin chủ nuôi</h6>
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-5 text-muted">Họ và tên</dt>
                    <dd class="col-7 fw-semibold">@Model.HoTen</dd>

                    <dt class="col-5 text-muted">Điện thoại</dt>
                    <dd class="col-7">
                        <a href="tel:@Model.SoDienThoai" class="text-decoration-none">@Model.SoDienThoai</a>
                    </dd>

                    <dt class="col-5 text-muted">Email</dt>
                    <dd class="col-7">@(string.IsNullOrEmpty(Model.Email) ? "—" : Model.Email)</dd>

                    <dt class="col-5 text-muted">Địa chỉ</dt>
                    <dd class="col-7">@(string.IsNullOrEmpty(Model.DiaChi) ? "—" : Model.DiaChi)</dd>

                    <dt class="col-5 text-muted">Ngày đăng ký</dt>
                    <dd class="col-7">@Model.NgayDangKy.ToString("dd/MM/yyyy")</dd>

                    <dt class="col-5 text-muted">Giới tính</dt>
                    <dd class="col-7 text-muted fst-italic">Chưa có dữ liệu</dd>
                </dl>
            </div>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-success text-white">
                <h6 class="mb-0">Thú cưng của chủ nuôi</h6>
            </div>
            <div class="card-body">
                @if (!Model.ThuCungs.Any())
                {
                    <p class="text-muted mb-0">Chủ nuôi chưa có thú cưng.</p>
                }
                else
                {
                    <div class="list-group list-group-flush">
                        @foreach (var pet in Model.ThuCungs)
                        {
                            <div class="list-group-item">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <div class="fw-semibold">@pet.TenThuCung</div>
                                        <div class="small text-muted">@pet.Loai @(!string.IsNullOrEmpty(pet.Giong) ? $"- {pet.Giong}" : "")</div>
                                    </div>
                                    <a class="btn btn-sm btn-outline-primary" asp-controller="ThuCung" asp-action="Details" asp-route-id="@pet.MaTc">Xem</a>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>
